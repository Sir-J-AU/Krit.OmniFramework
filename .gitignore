# Per-run test artefacts (default OutputDir is %LOCALAPPDATA% out-of-repo anyway)
tests/output/

# Editor / OS
.vs/
.vscode/.history/
*.swp
Thumbs.db
.DS_Store

# Backup snapshots
*.bak
*.bak.*

# Secrets — never commit
*.token
*-secret.txt
*-secrets.json
secrets/

# Build artefacts
out/
dist/
*.nupkg
*.zip

# Customer / engagement / Kritical-internal artefacts — never commit to this public toolkit repo.
# Pattern enforced so anything authored under one of these prefixes / paths is invisible to git
# regardless of where it lands inside the working tree.
**/_KRITICAL-INTERNAL-*
**/_KRITICAL-INTERNAL-*/
**/customer-*
**/aaa-CUSTOMERS/
**/*-FINAL-SHARED/
**/*-FINAL-SHARED-*/
**/Meetings/
**/EES/
**/Kitchenworx/
